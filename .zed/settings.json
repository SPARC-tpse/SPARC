{
  // Width of one tab stop in spaces (Python PEP8 = 4, JS/TS ecosystem = 2)
  "tab_size": 2,
  // Insert spaces instead of real tab characters — keeps diffs clean across editors
  "hard_tabs": false,
  // Wrap long lines visually without inserting newlines — helpful for Tailwind class strings
  "soft_wrap": "editor_width",
  // Global default: always auto-format when you save a file
  "format_on_save": "off",
  "languages": {
    "Python": {
      // Each Python indent level is 4 spaces
      "tab_size": 4,
      // Always auto-format when you save a file
      "format_on_save": "on",
      // Use Ruff as the primary formatter
      "formatter": {
        "external": {
          "command": "backend/.venv/bin/ruff",
          "arguments": ["format", "-"],
        },
      },
    },

    "Vue.js": {
      // Zed ships Volar support; this block enables additional Tailwind awareness
      "formatter": {
        "external": {
          "command": "prettier",
          // --plugin is needed so Prettier handles <template>, <script>, and <style> blocks
          "arguments": [
            "--parser", "vue",
            "--plugin", "prettier-plugin-tailwindcss",
            "--stdin-filepath", "{buffer_path}"
          ]
        }
      }
    },

    "TypeScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser", "typescript",
            "--plugin", "prettier-plugin-tailwindcss",
            "--stdin-filepath", "{buffer_path}"
          ]
        }
      }
    },

    "JavaScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser", "babel",
            "--plugin", "prettier-plugin-tailwindcss",
            "--stdin-filepath", "{buffer_path}"
          ]
        }
      }
    },

    "CSS": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--parser", "css", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },

    "JSON": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--parser", "json", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },

    "HTML": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser", "html",
            // Prettier wraps attributes alphabetically — useful for Tailwind class ordering
            "--html-whitespace-sensitivity", "css",
            "--stdin-filepath", "{buffer_path}"
          ]
        }
      }
    }
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "analysis": {
            "autoImportCompletions": true,
            "diagnosticMode": "workspace",
            "typeCheckingMode": "standard",
          },
        },
        "python": {
          "pythonPath": "backend/.venv/bin/python",
          "analysis": {
            "extraPaths": ["backend"],
          },
        },
      },
    },

    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          // Treat these custom attributes as class containers for autocomplete
          "classAttributes": ["class", ":class", "v-bind:class"],

          // Experimental class sorting on save (mirrors prettier-plugin-tailwindcss)
          "experimental": {
            "classRegex": [
              // Detects class strings inside cn(), clsx(), and twMerge() helper calls
              ["cn\\(([^)]*)\\)", "\"([^\"]*)\""],
              ["clsx\\(([^)]*)\\)", "\"([^\"]*)\""],
              ["twMerge\\(([^)]*)\\)", "\"([^\"]*)\""]
            ]
          }
        }
      }
    },

    "vue-language-server": {
      "settings": {
        "vue": {
          // Enables auto-imports inference from .nuxt/components.d.ts
          "autoInsertDotValue": true,
          // Infer prop types from defineProps<T>() generics
          "inlayHints": {
            "inlineHandlerLeading": true,
            "missingProps": true,
            "optionsWrapper": false
          }
        }
      }
    }
  },
}
